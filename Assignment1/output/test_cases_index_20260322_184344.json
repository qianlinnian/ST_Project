  "test_cases": [
    {
      "id": "TC001",
      "description": "测试 dayjs() 工厂函数传入 Dayjs 实例时返回克隆",
      "input": {
        "date": "dayjs实例",
        "c": null
      },
      "expected_output": "新的 Dayjs 实例（克隆）",
      "covered_branches": [
        "isDayjs(date) 为 true"
      ],
      "covered_paths": [
        "dayjs() -> isDayjs true -> date.clone()"
      ]
    },
    {
      "date": "2023-01-01",
      "c": {
        "locale": "en"
      }
    },
    {
      "id": "TC003",
      "description": "测试 dayjs() 工厂函数传入非 Dayjs 实例且 c 非对象",
      "input": {
        "date": "2023-01-01",
        "c": null
      },
      "expected_output": "新的 Dayjs 实例",
      "covered_branches": [
        "isDayjs(date) 为 false",
        "typeof c === 'object' 为 false"
      ],
      "covered_paths": [
        "dayjs() -> isDayjs false -> cfg 为 {} -> new Dayjs(cfg)"
      ]
    },
    {
      "id": "TC004",
      "description": "测试 parseLocale 传入空 preset",
      "input": {
        "preset": null,
        "object": null,
        "isLocal": false
      },
      "expected_output": "L（当前全局语言）",
      "covered_branches": [
        "!preset 为 true"
      ],
      "covered_paths": [
        "parseLocale -> !preset true -> return L"
      ]
    },
    {
      "id": "TC005",
      "description": "测试 parseLocale 传入字符串 preset 且已加载",
      "input": {
        "preset": "en",
        "object": null,
        "isLocal": false
      },
      "expected_output": "en",
      "covered_branches": [
        "typeof preset === 'string' 为 true",
        "Ls[presetLower] 存在",
        "!isLocal && l 为 true"
      ],
      "covered_paths": [
        "parseLocale -> string -> Ls[presetLower] true -> l = presetLower -> !isLocal && l true -> L = l -> return l"
      ]
    },
    {
      "preset": "zh-cn",
      "object": {
        "name": "zh-cn"
      },
      "isLocal": false
    },
    {
