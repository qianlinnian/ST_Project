    {
      "id": "TC011",
      "description": "测试日期比较 - isSame",
      "input": {
        "date1": "2023-10-01",
        "date2": "2023-10-01",
        "units": "D"
      },
      "expected_output": true,
      "covered_branches": [
        "isSame(that, units)"
      ],
      "covered_paths": [
        "dayjs -> isSame -> return this.startOf(units) <= other && other <= this.endOf(units)"
      ]
    },
    {
      "id": "TC012",
      "description": "测试日期比较 - isAfter",
