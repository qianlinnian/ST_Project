        "parseLocale函数 - typeof preset === 'string' 为 true 分支",
        "object 为 true 分支",
        "!isLocal && l 为 false 分支"
      ],
      "covered_paths": [
        "parseLocale -> 字符串预设 -> 语言未加载 -> 提供对象 -> 局部模式"
