  "test_cases": [
    {
      "id": "TC001",
      "description": "测试 dayjs() 工厂函数使用 null 作为输入，创建无效日期",
      "input": {
        "date": null
      },
      "expected_output": "Dayjs 实例，其 .isValid() 返回 false",
      "covered_branches": [
        "parseDate: date === null -> return new Date(NaN)"
      ],
      "covered_paths": [
        "dayjs(null) -> parseDate -> new Date(NaN)"
      ]
    },
    {
      "id": "TC004",
      "description": "测试 dayjs() 工厂函数传入一个有效格式的字符串（不含Z），且 cfg.utc 为 false",
      "input": {
        "date": "2024-01-15 10:30:45.123"
      },
      "expected_output": "Dayjs 实例，其 .$d 表示本地时间的 2024-01-15T10:30:45.123",
      "covered_branches": [
        "parseDate: date为字符串且不含Z，正则匹配成功 -> 返回本地时间Date"
      ],
      "covered_paths": [
        "dayjs(string) -> parseDate -> 正则匹配成功 -> 构造本地Date"
      ]
    },
    {
      "date": "2024-01-15 10:30:45.123",
      "c": {
        "utc": true
      }
    },
    {
      "id": "TC006",
