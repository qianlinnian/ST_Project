      "expected_output": false,
      "covered_branches": [
        "this.startOf(units) <= other 为 true",
        "other <= this.endOf(units) 为 false"
      ],
      "covered_paths": [
        "isSame() -> startOf() <= other true && other <= endOf() false -> return false"
      ]
    },
