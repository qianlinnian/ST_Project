      ],
      "covered_paths": [
        "parseLocale() -> !preset true -> return L"
      ]
    },
    {
      "id": "TC005",
      "description": "测试 parseLocale 传入字符串 preset 且已加载",
      "input": {
        "preset": "en",
        "object": null,
        "isLocal": false
      },
      "expected_output": "preset 的小写形式（如 'en'）",
      "covered_branches": [
        "typeof preset === 'string' 为 true",
        "Ls[presetLower] 存在",
        "!object 为 true",
        "!isLocal && l 为 true"
      ],
      "covered_paths": [
        "parseLocale() -> typeof preset === 'string' true -> Ls[presetLower] true -> l = presetLower -> !isLocal && l true -> L = l -> return l"
      ]
    },
    {
      "preset": "fr",
      "object": {
        "name": "fr"
      },
      "isLocal": false
    },
