    {
      "id": "TC021",
      "description": "测试 Dayjs.isSame() 相同日期相同单位",
      "input": {
        "that": "2023-01-01",
        "units": "day"
      },
      "expected_output": true,
      "covered_branches": [
        "this.startOf(units) <= other 为 true",
        "other <= this.endOf(units) 为 true"
      ],
      "covered_paths": [
        "isSame() -> startOf() <= other && other <= endOf() -> return true"
      ]
    },
    {
      "id": "TC022",
