  "test_cases": [
    {
      "id": "TC001",
      "description": "测试 dayjs() 工厂函数传入 Dayjs 实例时返回克隆",
      "input": {
        "date": "dayjs实例",
        "c": null
      },
      "expected_output": "新的 Dayjs 实例，与原实例值相同但引用不同",
      "covered_branches": [
        "isDayjs(date) 为 true"
      ],
      "covered_paths": [
        "dayjs() -> isDayjs(date) true -> date.clone()"
      ]
    },
    {
      "date": "2023-01-01",
      "c": {
        "locale": "zh-cn"
      }
    },
    {
      "id": "TC003",
      "description": "测试 dayjs() 工厂函数传入非 Dayjs 实例且 c 非对象",
      "input": {
        "date": "2023-01-01",
        "c": null
      },
      "expected_output": "新的 Dayjs 实例，配置为空对象",
      "covered_branches": [
        "isDayjs(date) 为 false",
        "typeof c === 'object' 为 false"
      ],
      "covered_paths": [
        "dayjs() -> isDayjs(date) false -> cfg = {} -> new Dayjs(cfg)"
      ]
    },
    {
      "id": "TC004",
      "description": "测试 parseLocale 传入空 preset 返回全局语言",
      "input": {
        "preset": null,
