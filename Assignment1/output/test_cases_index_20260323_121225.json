    {
      "id": "TC002",
      "description": "测试 dayjs 函数传入 null 日期",
      "input": {
        "date": null
      },
      "expected_output": "一个无效的 Dayjs 对象（isValid() 返回 false）",
      "covered_branches": [
        "parseDate 中 date === null 为 true"
      ],
      "covered_paths": [
        "dayjs -> parseDate -> date === null 路径"
      ]
    },
    {
      "id": "TC005",
      "description": "测试 dayjs 函数传入有效的日期字符串（非 Z 结尾）",
      "input": {
        "date": "2023-01-01 12:00:00"
      },
      "expected_output": "一个日期为 2023-01-01T12:00:00 的 Dayjs 对象",
      "covered_branches": [
        "parseDate 中 typeof date === 'string' 且 REGEX_PARSE 匹配成功"
      ],
      "covered_paths": [
        "dayjs -> parseDate -> 字符串解析成功路径"
      ]
    },
    {
