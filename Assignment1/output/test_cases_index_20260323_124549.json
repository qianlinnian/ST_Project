    {
      "id": "TC002",
      "description": "测试dayjs函数传入null日期",
      "input": {
        "date": null
      },
      "expected_output": "无效的Dayjs对象（isValid返回false）",
      "covered_branches": [
        "parseDate中date === null分支"
      ],
      "covered_paths": [
        "dayjs函数->parseDate->date===null->返回new Date(NaN)"
      ]
    },
    {
      "id": "TC005",
      "description": "测试dayjs函数传入有效日期字符串（非UTC）",
      "input": {
        "date": "2023-01-01 12:30:45.123"
      },
      "expected_output": "对应日期的Dayjs对象",
      "covered_branches": [
        "字符串匹配REGEX_PARSE成功且utc为false"
      ],
      "covered_paths": [
        "dayjs函数->parseDate->字符串匹配成功->返回new Date(...)"
      ]
    },
    {
      "id": "TC006",
      "description": "测试dayjs函数传入UTC日期字符串",
      "input": {
        "date": "2023-01-01T12:30:45Z"
      },
      "expected_output": "对应日期的Dayjs对象",
      "covered_branches": [
        "字符串以Z结尾，跳过正则匹配"
      ],
      "covered_paths": [
        "dayjs函数->parseDate->/Z$/i.test(date)为true->直接返回new Date(date)"
      ]
    },
    {
      "id": "TC007",
      "description": "测试dayjs函数传入无效日期字符串",
      "input": {
        "date": "invalid-date"
      },
      "expected_output": "无效的Dayjs对象",
      "covered_branches": [
        "字符串不匹配REGEX_PARSE"
      ],
      "covered_paths": [
        "dayjs函数->parseDate->正则匹配失败->返回new Date(date)"
      ]
    },
