{
  "name": "whitebox-test-generator",
  "private": true,
  "scripts": {
    "test": "jest"
  },
  "jest": {
    "testMatch": [
      "**/output/test_*.js",
      "**/__tests__/**/*.js",
      "**/*manual*dayjs*.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/"
    ],
    "moduleFileExtensions": [
      "js",
      "json"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "babel-jest": "^29.0.0",
    "istanbul-reports": "^3.2.0",
    "jest": "^29.0.0"
  }
}
